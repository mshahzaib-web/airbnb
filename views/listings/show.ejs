<% layout('/layouts/boilerplate') %>
<script>
  const coordinate = <%- JSON.stringify(listing.coordinate) %>;
</script>

<body>
  <div class="row">
    <div class="col-8 offset-2">
      <p><b>owner</b>: <i><%= listing.owner.username %></i></p>
      <h2><%= listing.title %></h2>
      <br />

      <div class="card">
        <img
          src="<%= listing.image.url %>"
          class="card-img-top show-img"
          alt="listing-image"
        />
        <div class="card-body">
          <b>
            <p class="pb-1"></p>
          </b>
          <div class="card-text">
            <p><%= listing.description %></p>
            <p>RS: <%= listing.price.toLocaleString("en-PK") %> /Night</p>
            <p><%= listing.location %></p>
            <p><%= listing.country %></p>
          </div>
        </div>
      </div>

      <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
      <div class="d-flex">
        <div>
          <button class="btn add-btn">
            <a href="/listings/<%= listing._id %>/edit">Edit Listing</a>
          </button>
        </div>
        <div>
          <form
            action="/listings/<%= listing._id %>?_method=DELETE"
            method="post"
          >
            <button class="btn add-btn">Delete</button>
          </form>
        </div>
      </div>
      <% } %>
    </div>
    <hr />
    <div class="col-8 offset-2 shadow p-3 mb-5 bg-body-dark rounded mt-2">
      <% if(currUser){ %>
      <h4>Leave a comment</h4>
      <form
        action="/listings/<%= listing._id %>/reviews"
        method="post"
        novalidate
        class="needs-validation"
      >
        <!-- <div class="mt-2">
          <label for="range" class="form-label">Rating</label>
          <input
            type="range"
            class="form-range"
            name="review[rating]"
            min="0"
            max="5"
            id="range"
          />
        </div> -->
        <fieldset class="starability-basic">
          <p class="mb-0">Rating:</p>
          <input
            type="radio"
            id="no-rate"
            class="input-no-rate"
            name="review[rating]"
            value="1"
            checked
            aria-label="No rating."
          />

          <input type="radio" id="rate1" name="review[rating]" value="1" />
          <label for="rate1">1 star.</label>

          <input type="radio" id="rate2" name="review[rating]" value="2" />
          <label for="rate2">2 stars.</label>

          <input type="radio" id="rate3" name="review[rating]" value="3" />
          <label for="rate3">3 stars.</label>

          <input type="radio" id="rate4" name="review[rating]" value="4" />
          <label for="rate4">4 stars.</label>

          <input type="radio" id="rate5" name="review[rating]" value="5" />
          <label for="rate5">5 stars.</label>

          <span class="starability-focus-ring"></span>
        </fieldset>
        <div class="mt-2 border border-5">
          <!-- <label for="comment" class="form-label">Comment</label> -->
          <textarea
            class="form-control"
            name="review[comment]"
            placeholder="Comment"
            id=""
            required
          ></textarea>

          <div class="invalid-feedback">Please add some comment</div>
        </div>
        <button class="btn btn-outline-danger mt-2 mb-2">Submit</button>
      </form>
      <% } %>
    </div>

    <hr />
    <% if(listing.review.length > 0){ %>
    <div class="col-8 offset-2">
      <h4>All Reviews</h4>
      <div class="row">
        <% for(rew of listing.review){ %>

        <div class="col-md-5 border border-5 shadow ms-3 mb-3">
          <p class="mb-0">@<i><%= rew.author.username %></i></p>

          <p class="starability-result" data-rating="<%= rew.rating %>">
            Rated: <%= rew.rating %> stars
          </p>
          <p class="card-text mb-2"><%= rew.comment %></p>
          <form
            action="/listings/<%= listing._id %>/reviews/<%= rew._id %>?_method=DELETE"
            method="post"
          >
            <% if(currUser && currUser._id.equals(rew.author._id)){ %>
            <button class="btn btn-outline-danger btn-sm mt-1">Delete</button>
            <% } %>
          </form>
        </div>

        <% } %>
      </div>
    </div>
    <% } %>
    <hr />
    <div class="col-8 offset-2">
      <h3>Where you'll be</h3>
      <div id="map"></div>
    </div>
  </div>
</body>
